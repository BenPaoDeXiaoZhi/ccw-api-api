  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "jest": "^30.4.2",
    "prettier-plugin-sort-members": "^0.2.4",
    "resolve-tspaths": "^0.8.23",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19"
