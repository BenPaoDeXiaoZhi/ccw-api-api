{
  "name": "@ccw-api/api",
  "version": "0.11.0",
  "description": "ccw api collections",
  "license": "MIT",
  "author": "Meng Fuzi",
  "homepage": "https://schale.qzz.io/ccw-api-api/",
  "type": "module",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./community-web": {
      "types": "./dist/community-web/index.d.ts",
      "import": "./dist/community-web/index.js",
      "require": "./dist/community-web/index.cjs"
    },
    "./community-web-cloud-database": {
      "types": "./dist/community-web-cloud-database/index.d.ts",
      "import": "./dist/community-web-cloud-database/index.js",
      "require": "./dist/community-web-cloud-database/index.cjs"
    },
    "./gandi-main": {
      "types": "./dist/gandi-main/index.d.ts",
      "import": "./dist/gandi-main/index.js",
      "require": "./dist/gandi-main/index.cjs"
    },
    "./op-parent-api": {
      "types": "./dist/op-parent-api/index.d.ts",
      "import": "./dist/op-parent-api/index.js",
      "require": "./dist/op-parent-api/index.cjs"
    },
    "./sso": {
      "types": "./dist/sso/index.d.ts",
      "import": "./dist/sso/index.js",
      "require": "./dist/sso/index.cjs"
    },
    "./setToken": {
      "types": "./dist/setToken.d.ts",
      "import": "./dist/setToken.js",
      "require": "./dist/setToken.cjs"
    },
    "./bfs-web": {
      "types": "./dist/bfs-web/index.d.ts",
      "import": "./dist/bfs-web/index.js",
      "require": "./dist/bfs-web/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "npm run build && npm test",
    "test": "node --import tsx --import ./env.ts --test \"src/**/*.test.ts\"",
    "test:dev": "node --import tsx --import ./env.ts --test --watch \"src/**/*.test.ts\"",
    "test:single": "node --import tsx --import ./env.ts --test",
    "doc": "typedoc",
    "doc:dev": "typedoc --watch",
    "build": "tsup"
  },
  "dependencies": {
    "@ccw-api/axios": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "dotenv": "^17.4.2",
    "prettier-plugin-sort-members": "^0.2.4",
    "resolve-tspaths": "^0.8.23",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.19"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
