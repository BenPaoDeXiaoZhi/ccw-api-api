{
  "name": "@ccw-api/api",
  "version": "1.0.2",
  "description": "ccw api collections",
  "license": "MIT",
  "author": "Meng Fuzi",
  "homepage": "https://schale.qzz.io/ccw-api-api/",
  "type": "module",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./community-web": {
      "types": "./dist/communityWeb.d.ts",
      "import": "./dist/communityWeb.js",
      "require": "./dist/communityWeb.cjs"
    },
    "./community-web-cloud-database": {
      "types": "./dist/communityWebDB.d.ts",
      "import": "./dist/communityWebDB.js",
      "require": "./dist/communityWebDB.cjs"
    },
    "./gandi-main": {
      "types": "./dist/gandiMain.d.ts",
      "import": "./dist/gandiMain.js",
      "require": "./dist/gandiMain.cjs"
    },
    "./op-parent-api": {
      "types": "./dist/opParent.d.ts",
      "import": "./dist/opParent.js",
      "require": "./dist/opParent.cjs"
    },
    "./sso": {
      "types": "./dist/sso.d.ts",
      "import": "./dist/sso.js",
      "require": "./dist/sso.cjs"
    },
    "./bfs-web": {
      "types": "./dist/bfs.d.ts",
      "import": "./dist/bfs.js",
      "require": "./dist/bfs.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "unpkg": "./dist/index.iife.js",
  "scripts": {
    "prepublishOnly": "npm run build && npm test",
    "test": "tsx --import ./src/before.test.ts --test",
    "doc": "typedoc",
    "doc:dev": "typedoc --watch",
    "build": "tsdown"
  },
  "dependencies": {
    "blueimp-md5": "^2.19.0"
  },
  "devDependencies": {
    "@ccw-api/request": "^1.2.1",
    "@types/blueimp-md5": "^2.18.2",
    "@types/node": "^26.0.1",
    "dotenv": "^17.4.2",
    "prettier-plugin-sort-members": "^0.2.4",
    "tsdown": "^0.22.9",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.19"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
