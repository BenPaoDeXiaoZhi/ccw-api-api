{
  "compilerOptions": {
    "declaration": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "paths": {
      "src*": ["./src*"],
      "types*": ["./types*"]
    }
  },
  "include": ["src", "types"]
}
